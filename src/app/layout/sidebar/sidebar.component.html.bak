<div
  class="fixed left-0 top-16 bottom-0 flex flex-col 
  bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl
  border-r border-gray-200/60 dark:border-slate-700/60
  shadow-sm z-40"
  [style.width]="getSidebarWidth()"
  [class.sidebar-expanded]="isExpanded()"
  [class.sidebar-collapsed]="!isExpanded()"
>

  <!-- 🔷 LOGO -->
  <div class="flex items-center gap-3 px-4 py-4 border-b border-gray-200 dark:border-slate-700
  transition-all duration-300">
    
    <div class="w-10 h-10 flex items-center justify-center rounded-xl 
    bg-gradient-to-br from-blue-500 to-indigo-600 text-white shadow-md
    flex-shrink-0">
      <i class="fa-solid fa-briefcase text-lg"></i>
    </div>

    <div *ngIf="isExpanded()" class="flex flex-col leading-tight min-w-0 animate-in fade-in duration-200">
      <span class="text-sm font-semibold text-gray-800 dark:text-white truncate">
        {{ getLogoText() }}
      </span>
      <span class="text-xs text-gray-400 truncate">Dashboard</span>
    </div>

  </div>

  <!-- 🔷 MENU -->
  <nav class="flex-1 px-2 py-3 space-y-1 overflow-y-auto">

    <div *ngFor="let item of menuItems()" class="space-y-1 relative transition-all duration-200">

      <!-- 🔹 MAIN ITEM -->
      <button
        (click)="handleMenuClick($event, item)"
        [routerLink]="!hasChildren(item) ? item.route : null"

        (mouseenter)="setHoveredMenu(item.id)"
        (mouseleave)="setHoveredMenu(null)"

        [title]="!isExpanded() ? item.label : ''"

        class="group relative w-full flex items-center gap-3 px-3 py-2.5 rounded-xl
        text-sm font-medium transition-all duration-200
        text-gray-600 dark:text-slate-300
        hover:bg-gray-100 dark:hover:bg-slate-800
        hover:text-blue-600 dark:hover:text-blue-400"

        [class.bg-blue-50]="isItemActive(item)"
        [class.dark:bg-blue-900]="isItemActive(item)"
        [class.text-blue-600]="isItemActive(item)"
        [class.dark:text-blue-300]="isItemActive(item)"
       >

        <!-- Active Indicator -->
        <span *ngIf="isItemActive(item)"
          class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-6 rounded-r bg-blue-600
          transition-all duration-300">
        </span>

        <!-- Icon -->
        <i class="w-5 h-5 flex items-center justify-center text-base flex-shrink-0"
           [ngClass]="item.iconClass || 'fa-solid fa-circle'">
        </i>

        <!-- Label -->
        <span *ngIf="isExpanded()" class="flex-1 truncate transition-opacity duration-200">
          {{ item.label }}
        </span>

        <!-- Arrow -->
        <i *ngIf="hasChildren(item) && isExpanded()"
           class="fa-solid fa-chevron-down text-xs transition-transform duration-300 flex-shrink-0"
           [class.rotate-180]="isMenuExpanded(item.id)">
        </i>

      </button>

      <!-- 🔹 FLOAT MENU (Collapsed Mode) -->
      <div
        *ngIf="hasChildren(item) && !isExpanded() && hoveredMenuId() === item.id"
        class="absolute left-full top-0 ml-3 w-56 bg-white dark:bg-slate-800
        border border-gray-200 dark:border-slate-700 rounded-xl shadow-xl p-2 z-50
        animate-in fade-in slide-in-from-left-2 duration-200"
      >
        <button
          *ngFor="let child of item.children"
          [routerLink]="child.route"

          class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm
          text-gray-600 dark:text-slate-300 transition-all duration-150
          hover:bg-gray-100 dark:hover:bg-slate-700
          hover:text-blue-600 dark:hover:text-blue-400"

          [class.bg-blue-50]="isRouteActive(child.route)"
          [class.dark:bg-blue-900]="isRouteActive(child.route)"
          [class.text-blue-600]="isRouteActive(child.route)"
        >
          <i class="w-4 h-4 flex-shrink-0" [ngClass]="child.iconClass"></i>
          <span class="truncate">{{ child.label }}</span>
        </button>
      </div>

      <!-- 🔹 EXPANDED SUBMENU -->
      <div
        *ngIf="hasChildren(item) && isExpanded() && isMenuExpanded(item.id)"
        class="ml-6 pl-3 border-l border-gray-200 dark:border-slate-700 space-y-1
        animate-in fade-in slide-in-from-top-1 duration-200"
      >

        <button
          *ngFor="let child of item.children"
          [routerLink]="child.route"

          class="w-full flex items-center gap-2 px-2 py-2 rounded-lg text-sm
          text-gray-500 dark:text-slate-400 transition-all duration-150
          hover:bg-gray-100 dark:hover:bg-slate-800
          hover:text-blue-600 dark:hover:text-blue-400"

          [class.bg-blue-50]="isRouteActive(child.route)"
          [class.dark:bg-blue-950]="isRouteActive(child.route)"
          [class.text-blue-600]="isRouteActive(child.route)"
        >
          <i class="text-xs flex-shrink-0" [ngClass]="child.iconClass"></i>
          <span class="truncate">{{ child.label }}</span>
        </button>

      </div>

    </div>

  </nav>

  <!-- 🔷 FOOTER USER -->
  <div class="p-3 border-t border-gray-200 dark:border-slate-700 transition-all duration-300">

    <div class="flex items-center gap-3 p-2 rounded-xl 
    hover:bg-gray-100 dark:hover:bg-slate-800 cursor-pointer transition-colors duration-200">

      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex-shrink-0"></div>

      <div *ngIf="isExpanded()" class="flex-1 min-w-0 animate-in fade-in duration-200">
        <p class="text-sm font-medium text-gray-700 dark:text-white truncate">User</p>
        <p class="text-xs text-gray-400 truncate">Admin</p>
      </div>

    </div>

  </div>
</div>
      <div
        *ngIf="hasChildren(item) && isExpanded() && (item.isExpanded || hasActiveChild(item))"
        class="ml-6 pl-3 border-l border-gray-200 dark:border-slate-700 space-y-1"
      >

        <button
          *ngFor="let child of item.children"
          [routerLink]="child.route"

          class="w-full flex items-center gap-2 px-2 py-2 rounded-lg text-sm
          text-gray-500 dark:text-slate-400
          hover:bg-gray-100 dark:hover:bg-slate-800
          hover:text-blue-600 dark:hover:text-blue-400
          transition-all"

          [class.bg-blue-50]="isRouteActive(child.route)"
          [class.dark:bg-blue-950]="isRouteActive(child.route)"
          [class.text-blue-600]="isRouteActive(child.route)"
        >
          <i class="text-xs" [ngClass]="child.iconClass"></i>
          <span>{{ child.label }}</span>
        </button>

      </div>

    </div>

  </nav>

  <!-- 🔷 FOOTER USER -->
  <div class="p-3 border-t border-gray-200 dark:border-slate-700">

    <div class="flex items-center gap-3 p-2 rounded-xl 
    hover:bg-gray-100 dark:hover:bg-slate-800 cursor-pointer">

      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-pink-500"></div>

      <div *ngIf="isExpanded()" class="flex-1">
        <p class="text-sm font-medium text-gray-700 dark:text-white">User</p>
        <p class="text-xs text-gray-400">Admin</p>
      </div>

    </div>

  </div>

</div>